{
    "source": {
        "include": [
            "./lib/docs/"
        ]
    },
    "plugins": [
        "plugins/markdown"
    ],
    "opts": {
        "recurse": true,
        "private": false,
        "lenient": false,
        "destination": "./docs",
        "template": "./node_modules/jsdoc-jibo",
        "readme": "./tasks/docs.md"
    }
}