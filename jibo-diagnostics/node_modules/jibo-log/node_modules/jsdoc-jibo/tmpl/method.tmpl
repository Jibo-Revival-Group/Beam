<?js
var data = obj;
var self = this;
if(data.kind !== 'module'){
?>
<?js if(data.kind !== 'class') { ?>
  <h3><?js= name + (data.signature || '') ?></h3>
<?js } ?>
<section class="method">
<?js if (data.kind !== 'module') { ?>
  <?js if (data.kind === 'class') { ?>
    <?js if(data.description) { ?>
      <div class="description">
        <?js= data.description ?>
      </div>
    <?js } ?>
<table class="api constructor">
  <thead>
    <tr>
      <th>
      Constructor
      </th>
    </tr>
  </thead>
  <tr>
  <td>
  <p>
   <code><?js= (kind === 'class' ? 'new ' : '') +
name + (data.signature || '') ?></code>
  </p>
  </td>
  </tr>
</table>
<?js } ?>
<?js if (data.deprecated) { ?>

<div data-alert class="callout warning important tag-deprecated"><?js
    if (data.deprecated === true) { ?>Deprecated<?js }
    else { ?>Deprecated <?js= data.deprecated ?><?js } ?>
</div>
<?js } ?>
<?js if (data.summary) { ?>

<p class="summary"><?js= summary ?></p>
<?js } ?>
<?js } ?>
<?js if (data.kind !== 'module' && data.kind !== 'class' && data.description) { ?>
<div class="description">
<?js= data.description ?>
</div>
<?js } ?>
<?js if (data.augments && data.alias && data.alias.indexOf('module:') === 0) { ?>
  
  <div class="extends">This class extends <?js= self.partial('augments.tmpl', data) ?></div>
<?js } ?>

<?js if (data['this']) { ?>

<div class="details">
  This: <?js= this.linkto(data['this'], data['this']) ?>
</div>
<?js } ?>
<?js if (data.params && params.length) { ?>
  
  <?js= this.partial('params.tmpl', params) ?>
<?js } ?>
<?js if (data.returns && returns.length) { ?>
  
  <table class="api returns">
    <thead>
      <tr>
        <td colspan="2">
          Returns
        </td>
      </tr>
      </thead>
      <tbody>
        <?js
          returns.forEach(function(r) { ?>
            <?js= self.partial('returns.tmpl', r) ?>
          <?js }); ?>
      </tbody>
      </table>
<?js } ?>
<?js= this.partial('details.tmpl', data) ?>
<?js if (data.kind !== 'module' && data.requires && data.requires.length) { ?>
  
<h5>Requires:</h5> 
<?js 
var c = 1;
data.requires.forEach(function(r) { ?>
<?js= self.linkto(r) ?><?js if (c < data.requires.length){ ?>,<?js } ?>
<?js
c++;
 }); ?></ul>
<?js } ?>
<?js if (data.fires && fires.length) { ?>
  
<h4>Fires:</h4>
<ul><?js fires.forEach(function(f) { ?>
<li><?js= self.linkto(f) ?></li>
<?js }); ?></ul>
<?js } ?>
<?js if (data.listens && listens.length) { ?>

<h5>Listens to Events:</h5>
<ul><?js listens.forEach(function(f) { ?>
<li><?js= self.linkto(f) ?></li>
<?js }); ?></ul>
<?js } ?>

<?js if (data.listeners && listeners.length) { ?>

<h5>Listeners of This Event:</h5>
<ul><?js listeners.forEach(function(f) { ?>
<li><?js= self.linkto(f) ?></li>
<?js }); ?></ul>
<?js } ?>

<?js if (data.exceptions && exceptions.length) { ?>

<h5>Throws:</h5>
<?js if (exceptions.length > 1) { ?><ul><?js
exceptions.forEach(function(r) { ?>
<li><?js= self.partial('exceptions.tmpl', r) ?></li>
<?js });
?></ul><?js } else {
exceptions.forEach(function(r) { ?>
<?js= self.partial('exceptions.tmpl', r) ?>
<?js });
} } ?>
<?js if (data.examples && examples.length) { ?>
  
<h5>Example<?js= examples.length > 1? 's':'' ?></h5>
<?js= this.partial('examples.tmpl', examples) ?>
<?js } ?>
</section>
<?js  } ?> 
