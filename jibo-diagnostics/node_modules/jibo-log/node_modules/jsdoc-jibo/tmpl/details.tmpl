<?js
var data = obj;
var self = this;
var defaultObjectClass = '';

// Check if the default value is an object or array; if so, apply code highlighting
if (data.defaultvalue && (data.defaultvaluetype === 'object' || data.defaultvaluetype === 'array')) {
  data.defaultvalue = "```" + data.defaultvalue + "```";
  defaultObjectClass = ' class="object-value"';
}
?>
<?js
var properties = data.properties;
if (properties && properties.length && properties.forEach) {
?>
  <?js= this.partial('properties.tmpl', data) ?>
<?js } ?>
<?js if (data.version) {?>
  <span class="tag-version">Version: </span><?js= version ?>
<?js } ?>
<?js if (data.since) {?>
  <span class="tag-since">Since: </span><?js= since ?>
<?js } ?>
<?js if (data.inherited && data.inherits && !data.overrides) { ?>
  <p>
    Inherited From: <?js= this.linkto(data.inherits, this.htmlsafe(data.inherits)) ?>
  </p>
<?js } ?>
<?js if (data.overrides) { ?>
  <span class="tag-overrides">Overrides: </span><?js= this.linkto(data.overrides, this.htmlsafe(data.overrides)) ?>
<?js } ?>

<?js if (data.implementations && data.implementations.length) { ?>
<dt class="implementations">Implementations:</dt>
  <dd class="implementations">
    <ul>
    <?js data.implementations.forEach(function(impl) { ?>
      <li><?js= self.linkto(impl, self.htmlsafe(impl)) ?></li>
<?js }); ?>
    </ul>
  </dd>
<?js } ?>

<?js if (data.implements && data.implements.length) { ?>
<span class="implements">Implements: </span>
<?js data.implements.forEach(function(impl) { ?>
<?js= self.linkto(impl, self.htmlsafe(impl)) ?>
<?js }); ?>
<?js } ?>

<?js if (data.mixes && data.mixes.length) { ?>
<dt class="mixes">Mixes In:</dt>

<dd class="mixes"><ul>
<?js data.mixes.forEach(function(a) { ?>
<li><?js= self.linkto(a, a) ?></li>
<?js }); ?>
</ul></dd>
<?js } ?>

<?js if (data.author && author.length) {?>
<dt class="tag-author">Author:</dt>
<dd class="tag-author">
<ul><?js author.forEach(function(a) { ?>
<li><?js= self.resolveAuthorLinks(a) ?></li>
<?js }); ?></ul>
</dd>
<?js } ?>

<?js if (data.copyright) {?>
<dt class="tag-copyright">Copyright:</dt>
<dd class="tag-copyright"><ul class="dummy"><li><?js= copyright ?></li></ul></dd>
<?js } ?>

<?js if (data.license) {?>
<dt class="tag-license">License:</dt>
<dd class="tag-license"><?js= license ?></dd>
<?js } ?>

<?js if (data.defaultvalue) {?>
<dt class="tag-default">Default Value: </dt>
<dd class="tag-default"><?js= data.defaultvalue ?>
</ul></dd>
<?js } ?>

<?js if (data.meta && self.outputSourceFiles) {?>
<dt class="tag-source">Source:</dt>
<dd class="tag-source"><ul class="dummy"><li>
<?js= self.linkto(meta.shortpath) ?>, <?js= self.linkto(meta.shortpath, 'line ' + meta.lineno, null, 'line' + meta.lineno) ?>
</li></ul></dd>
<?js } ?>

<?js if (data.tutorials && tutorials.length) {?>
<dt class="tag-tutorial">Tutorials:</dt>
<dd class="tag-tutorial">
<?js tutorials.forEach(function(t) { ?>
<?js= self.tutoriallink(t) ?><br>
<?js }); ?>
</dd>
<?js } ?>

<?js if (data.see && see.length) {?>
See <?js see.forEach(function(s,i) { ?><?js= self.linkto(s) ?><?js if(i < see.length - 1){ ?>,<?js } ?> <?js }); ?>
<?js } ?>

<?js if (data.todo && todo.length) {?>
<dt class="tag-todo">To Do:</dt>
<dd class="tag-todo">
<ul><?js todo.forEach(function(t) { ?>
<li><?js= t ?></li>
<?js }); ?></ul>
</dd>
<?js } ?>
</dl>
