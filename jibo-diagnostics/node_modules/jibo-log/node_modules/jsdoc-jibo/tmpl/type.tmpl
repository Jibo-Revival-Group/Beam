<?js
var data = obj;
var self = this;
data.forEach(function(name, i) { 
  var l = self.linkto(name, self.htmlsafe(name)).replace(/~/g,'');
  var matches = l.match(/#.*/) || [];
  var hash = matches.length ? matches[0] : '';
  l = l.replace(hash,'') + hash.toLowerCase();
?>
  <span class="param-type">:<?js= l ?></span><?js if(i < data.length - 1){ ?>, <?js } ?>
<?js }); ?>