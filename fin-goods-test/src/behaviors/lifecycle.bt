        "options": {
            "getTarget": [
                "() => {",
                "\tlet x = 1 - 2 * Math.random();",
                "\tlet y = 1 - 2 * Math.random();",
                "\tlet z = 0.7 + 0.5 * (1 - 2 * Math.random());",
                "\treturn {x: x, y: y, z: z};",
                "}"
            ]
        }
    },
    "18": {
        "id": 18,
        "class": "ExecuteScript",
        "name": "",
        "asset-pack": "core",
        "parent": 21,
        "decorators": [],
        "options": {
            "exec": [
                "() => {",
                "  let timeDiff = process.hrtime(notepad.hrStart);",
                "  document.getElementById('test-label3').innerHTML = 'animating time: ' + timeDiff[0] + 's';",
                "//  console.log(\"time diff vs cycle length = \" + timeDiff[0] + \"/\" + notepad.cycleLength);",
                "  if (timeDiff[0] >= notepad.cycleLength) {",
                "    // tell everyone to stop",
                "    notepad.running = false;",
                "  }",
                "}"
            ]
        }
    },
