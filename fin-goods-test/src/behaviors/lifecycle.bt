        "options": {
            "exec": [
                "() => {",
                "  notepad.running = true;",
                "  notepad.resting = false;",
                "  notepad.cycleLength = 240; // 240 ~= 4 mins",
                "  notepad.hrStart = process.hrtime();",
                "  notepad.hrRestStart = 0;",
                "}"
            ]
        }
