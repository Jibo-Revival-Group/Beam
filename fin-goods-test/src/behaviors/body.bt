    "5": {
        "id": 5,
        "class": "ExecuteScript",
        "name": "get random anim speed",
        "asset-pack": "core",
        "parent": 1,
        "args": [
            [
                "() => {",
                "  notepad.animSpeed = parseFloat(Math.random() * (0.75 - 0.60) + 0.60).toFixed(2); // between 0.60-0.75",
                "  document.getElementById('test-label3').innerHTML = 'anim speed: ' + notepad.animSpeed * 100 + \"%\";",
                "}"
            ]
        ]
    },
