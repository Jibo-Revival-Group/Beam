{
    "1": {
        "id": 1,
        "class": "Sequence",
        "name": "",
        "args": [],
        "children": [
            11
        ],
        "decorators": []
    },
    "11": {
        "id": 11,
        "class": "LookAt",
        "name": "follow me with a continuous look at!",
        "asset-pack": "core",
        "parent": 1,
        "args": [
            [
                "() => {",
                "\tlet jibo = require('jibo');\t",
                "\tlet entity = jibo.lps.getClosestVisualEntity();",
                "",
                "\tlet position = {x:.5, y:.1, z:.4};",
                "",
                "\tif (entity && entity.parts.length > 0) {",
                "\t\tlet raysData = entity.parts[0].value.rays;",
                "",
                "\t\tif (raysData !== undefined && raysData.length > 0) {",
                "\t\t\tdocument.getElementById('test-label').innerHTML = \"Found you :)\";",
                "",
                "\t\t\tlet origin = entity.parts[0].value.rays[0].origin;",
                "\t\t\tlet dir = entity.parts[0].value.rays[0].dir;",
                "\t\t\t",
                "\t\t\tposition\t= {x: dir.x + origin.x, y:dir.y + origin.y, z: dir.z + origin.z};",
                "",
                "\t\t\tdocument.getElementById('test-label').innerHTML = `Found you at ${position.x.toPrecision(3)}, ${position.y.toPrecision(3)}, ${position.z.toPrecision(3)}`;\t",
                "\t\t}",
                "\t}",
                "\telse {",
                "\t\tdocument.getElementById('test-label').innerHTML = \"Lost you :(\";",
                "\t}",
                "",
                "\treturn position;",
                "}"
            ],
            true,
            [
                "(lookAt) => {",
                "}"
            ]
        ]
    }
}