{
  "name": "@jibo/parser-download",
  "version": "3.4.0",
  "description": "Tool for downloading platform specific versions of jibo-parser",
  "license": "UNLICENSED",
  "distribution": "PROPRIETARY AND CONFIDENTIAL - NOT FOR DISTRIBUTION",
  "copyright": "Copyright (c) 2014-2018 Jibo, Inc. All Rights Reserved",
  "bin": "./bin/parser-download.js",
  "main": "./lib/parser-download.js",
  "scripts": {
    "test": "gulp test  && istanbul report && npm run coverage:check",
    "test:report": "gulp test-report",
    "build": "gulp debug",
    "build:release": "gulp",
    "clean": "gulp clean-all",
    "coverage:check": "istanbul check-coverage --statements 30 --branches 20 --functions 30 --lines 30",
    "coverage:report": "istanbul report && open coverage/lcov-report/index.html",
    "coverage:remap": "remap-istanbul --input ./coverage/coverage-final.json --output ./coverage/coverage-final.json -b parser-download/",
    "watch": "gulp watch"
  },
  "typings": "lib/dts/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git@github.jibo.com:sdk/parser-download.git"
  },
  "publishConfig": {
    "registry": "http://npm.jibo.com:8080"
  },
  "engines": {
    "node": ">=6.0"
  },
  "files": [
    "bin",
    "lib"
  ],
  "dependencies": {
    "chalk": "^2.2.0",
    "env-paths": "^1.0.0",
    "extract-zip": "^1.5.0",
    "fs-extra": "^5.0.0",
    "minimist": "^1.2.0",
    "nugget": "^2.0.0",
    "uuid": "^3.2.1"
  },
  "devDependencies": {
    "@types/chalk": "^2.2.0",
    "@types/fs-extra": "^5.0.0",
    "@types/minimist": "^1.2.0",
    "@types/node": "6.0.94",
    "@types/uuid": "^3.4.3",
    "gulp": "^3.9.1",
    "istanbul": "^0.4.5",
    "jibo-gulp": "^6.0.1"
  }
}
