{
  "name": "@be/bad-apple",
  "version": "0.1.0",
  "description": "Bad Apple!! PV on Jibo's face. Swipe down to exit.",
  "main": "index.js",
  "config": {
    "standalone": true
  },
  "jibo": {
    "main": "index.html",
    "type": "asset-pack",
    "launchRule": "launch.rule",
    "prompt": "Bad Apple",
    "display-name": "bad-apple"
  },
  "monorailConfig": {
    "public": false,
    "output": "index.js"
  },
  "scripts": {
    "build": "node ../../jibo-dev/build-bad-apple.js ."
  },
  "files": [
    "resources",
    "video",
    "index.*",
    "launch.rule",
    "NOTICE"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=6.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@be/be-framework": "^11.0.0",
    "jibo": "^14.0.0"
  },
  "syncDependencies": [
    "jibo",
    "@be/be-framework"
  ]
}
