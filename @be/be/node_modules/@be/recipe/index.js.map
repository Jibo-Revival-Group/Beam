                        'frm': 'bab310b9-cd93-49e2-a72c-d37914add491',
                        'to': '1b2ef999-bea0-4b5c-baef-3442424da40a',
                        'value': ''
                    }],
                'exceptions': [],
                'class': 'Flow.Eval-Async',
                'options': {
                    'exec': done => {
                        let id = blackboard.activeRecipe.recipeID;
                        const update = () => {
                            notepad.view.favoriteBtn.toggle();
                            done();
                        };
                        if (blackboard.stateModel.isFavoriteRecipe(id)) {
                            blackboard.stateModel.removeFavoriteRecipe(id).then(update);
                        } else {
                            blackboard.stateModel.addFavoriteRecipe(id).then(update);
                        }
                    },
                    'onStop': () => {
                    }
                }
            };
        },
