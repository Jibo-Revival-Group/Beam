                            name: blackboard.userModel.name,
                            meal,
                            greeting
                        };
                        let question_1 = blackboard.StringUtils.supplant(blackboard.languageData.WHAT_DO_YOU_WANT_WHAT_DO_YOU_WANT_PROMPT_1, data);
                        let question_2 = blackboard.StringUtils.supplant(blackboard.languageData.WHAT_DO_YOU_WANT_WHAT_DO_YOU_WANT_PROMPT_2, data);
