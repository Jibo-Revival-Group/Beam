                            notepad.query.method = 'getRecommendations';
                            break;
                        case 'token':
                            notepad.token = notepad.query.args = nl.token;
                            notepad.query.meal = nl.meal;
                            notepad.query.method = 'getRecipesByGenericFilter';
                            break;
                        case 'favorites':
                            notepad.query.method = 'getFavorites';
                            break;
                        }
                        return r;
                    },
                    'onFailure': results => {
                        notepad.query = { method: 'getRecommendations' };
