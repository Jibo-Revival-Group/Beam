TopRule = $* (
  $FAVORITES |
  $RECOMMENDATION |
  $RECIPE_OR_INGREDIENT
) $*;

FAVORITES = (
  (my | our | saved | the) [favorite?s]
) {%response='favorites'%};

RECOMMENDATION = (
    recommend |
    recommendation |
    (no | nope | nah) |
    (not really) |
    ((don\'t | do not) know) |
    (no (idea | clue)) |
    surprise |
    (you (choose | pick | tell)) |
    ((have | do) you (got | have))
) {%response='recommendation'%} ?(?for (me | us | $MEAL));

# The captured token here is parsed again by regular expressions to support a wider range of inputs.
RECIPE_OR_INGREDIENT = (
    <1.0>?(have | has | with | got | like | make | try | want | need | <0.0>me<1.0> | something | that | about)<0.0>
    ?(some | for | a | at | in | with | has)
    <0.9> $TOKEN <0.0>
    ?((for $MEAL) | please | [sound?s] | will | is | in | would | a | [recipe?s] | [option?s])
) {%response='token'%};

TOKEN @= +$w {%token=this._parsed%};
MEAL @= (breakfast|lunch|dinner|supper) {%meal=this._parsed%};
