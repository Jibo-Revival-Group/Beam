TopRule = $* (
    $NEXT |
    $PREVIOUS |
    $REPLAY_CURRENT |
    $REPLAY_OTHER |
    $JUMP_BACK |
    $INGREDIENTS |
    $CANCEL |
    $COMPLETE |
    $VIDEO
) $*;

NEXT = (next | go | continue | ready) {%response='nav'%} {%step='next'%};
PREVIOUS = previous {%response='nav'%} {%step='previous'%};

REPLAY_CURRENT = (
    ((play | replay | show | repeat) ?me ?that ?(one | step) ?again) {%step='current'%}
) {%response='nav'%};

REPLAY_OTHER @= (
    ((play | replay | show | repeat | ((jump | go) to)) $w03 step ?(number) $STEP_CAPTURE ?(again))
) {%response='nav'%};

STEP_CAPTURE @= $w {%step=this._parsed%};

JUMP_BACK = ((jump | go) back) {%response='nav'%} {%step='back'%};

INGREDIENTS = ((show | what | forgot) $* [ingredient?s]) {%response='ingredients'%};

COMPLETE = (done | finished | complete) {%response='complete'%};

CANCEL = (quit | cancel | exit) {%response='cancel'%};

VIDEO = (video) {%response='video'%};
