TopRule = $* (
    $MAKE |
    # $FILTER |
    $RESET |
    $NAV |
    $INGREDIENTS |
    $SERVING |
    $TIME |
    $RATING |
    $VIDEO |
    $FAVORITE |
    $RESTART
) $*;

MAKE = (
    ((bake | make | cook | prepare | eat | (go with)) ?(it | this | that))
) {%response='make'%};

FILTER = (
    ($REMOVE | $ADD) ?(?(recipes | meals | dishes | food) (with | that (have | has))) +$w {%token=this._parsed%}
) {%response='filter'%};
REMOVE = (remove | exclude | (take out) | (don\'t want)) {%action='remove'%};
ADD = (add | include | (put in)) {%action='add'%};

RESET = (
    (have | has | with | want | got | like | make | try | search | for | show)
    (some | a | (<1.0>for<0.0>) | (?me my))
    <1.0>$RESET_CAPTURE<0.0>
    ?(instead | [recipe?s])
) {%response='reset'%};
RESET_CAPTURE @= +$w {%token=this._parsed%};

NAV = ($NEXT | $PREVIOUS) {%response='nav'%};
NEXT = (another | next | skip | pass | (keep going)) {%direction='next'%};
PREVIOUS = (previous | back | last) {%direction='previous'%};

INGREDIENTS = [ingredient?s] {%response='ingredients'%};

SERVING = (
    serve |
    serving |
    (people $* feed) |
    ([feed?s] $* people)
) {%response='serving'%};

TIME = (
    (how long) |
    ((prep | cook) time)
) {%response='time'%};

RATING = (
    rating |
    stars
) {%response='rating'%};

VIDEO = video {%response='video'%};

FAVORITE = <0.5>(favorite | unfavorite) {%response='favorite'%};

RESTART = (
    restart |
    (none of these) |
    (don\'t like any of (these | those))
) {%response='restart'%};
