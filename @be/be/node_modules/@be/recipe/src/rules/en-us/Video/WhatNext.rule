TopRule = $* (
  $PLAY |
  $PAUSE |
  $CLOSE |
  $VOLUME |
  $JUMP |
  $MAKE
) $*;

PLAY = (play | replay | restart | again) {%response='play'%};
PAUSE = pause {%response='pause'%};
CLOSE = (close | stop | (go back)) {%response='close'%};

VOLUME = (sound | volume | mute | unmute) {%response='volume'%};

JUMP = ?((go | jump) to) (step | number) $STEP {%response='jump'%};
STEP @= $w {%step=this._parsed%};

MAKE = make {%response='make'%};
