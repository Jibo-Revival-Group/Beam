TopRule = $* (
    $CLOSE |
    $MAKE_IT |
    $READ |
    $HOW_MANY |
    $HOW_MUCH
) $*;

CLOSE = (
  close |
  back
) {%response='close'%};

MAKE_IT = (
  make |
  cook
) {%response='make'%};

READ = (
    repeat |
    read |
    say |
    tell |
    aloud
) {%response='read'%};

HOW_MANY = (
    how many [ingredient?s]
) {%response='how-many'%};

HOW_MUCH @= (
    how (many | much) <1.0> $CAPTURE <0.0> ?(do | is | are | does | am | will)
) {%response='how-much'%};

CAPTURE @= +$w {%ingredient=this._parsed%};
