        {
            "class": "Mim.Question",
            "clazz": "Mim.Question",
            "loc": "727.8792012508461 -928.5",
            "id": "f2c13a3b-d9da-4db6-b023-c1c2324aa8d4",
            "options": {
                "mimPath": "mims/en-us/RecipeSelection/WhatNext.mim",
                "getPromptData": [
                    "() => {",
                    "  let data = {",
                    "    title: blackboard.activeRecipe.title,",
                    "    rating: Math.round(blackboard.activeRecipe.ratingAverage)",
                    "  };",
                    "  ",
                    "  let question_1 = blackboard.StringUtils.supplant(",
                    "    blackboard.languageData.RECIPE_SELECTION_WHAT_NEXT_PROMPT_1,",
                    "    data",
                    "  );",
                    "  ",
                    "  let question_2 = blackboard.StringUtils.supplant(",
                    "    blackboard.languageData.RECIPE_SELECTION_WHAT_NEXT_PROMPT_2,",
                    "    data",
                    "  );",
                    "  ",
                    "  let question_3 = blackboard.StringUtils.supplant(",
                    "    blackboard.languageData.RECIPE_SELECTION_WHAT_NEXT_PROMPT_3,",
                    "    data",
                    "  );",
                    "  ",
                    "  let noInput_1 = blackboard.StringUtils.supplant(",
                    "    blackboard.languageData.RECIPE_SELECTION_WHAT_NEXT_NO_INPUT_1,",
                    "    data",
                    "  );",
                    "  ",
                    "  let noMatch_1 = blackboard.StringUtils.supplant(",
                    "    blackboard.languageData.RECIPE_SELECTION_WHAT_NEXT_NO_MATCH_1,",
                    "    data",
                    "  );",
                    "  ",
                    "  return {",
                    "    numMatches: blackboard.filteredRecipes.length,",
                    "    silence: notepad.silence,",
                    "    firstRecipe: notepad.firstRecipe,",
                    "    question_1,",
                    "    question_2,",
                    "    question_3,",
                    "    noInput_1,",
                    "    noMatch_1",
                    "  };",
                    "}",
                    "",
                    ""
                ],
                "onStatus": [
                    "(status) => {",
                    "",
                    "}"
                ],
                "onSuccess": [
                    "(results) => {",
                    "\tlet nl = results.asrResults.NLParse;",
                    "\tlet response = nl.response;",
                    "\tnotepad.token = nl.token;",
                    "\tswitch (response) {",
                    "\t\tcase 'reset':",
                    "\t\t\tif (/favorite/i.test(nl.token)) {",
                    "\t\t\t\tnotepad.query = { method: 'getFavorites' };",
                    "\t\t\t\tbreak;",
                    "\t\t\t}",
                    "\t\tcase 'filter':",
                    "\t\t\t// TODO: Add filter path to Load Data",
                    "\t\t\tnotepad.query = {",
                    "\t\t\t\targs: nl.token,",
                    "\t\t\t\tmethod: 'getRecipesByGenericFilter'",
                    "\t\t\t};",
                    "\t\t\tbreak;",
                    "\t\tcase 'nav':",
                    "\t\t\tnotepad.direction = nl.direction;",
                    "\t\t\tbreak;",
                    "\t}",
                    "\treturn response;",
                    "}",
                    ""
                ],
                "onFailure": [
                    "(results) => {",
                    "\tlet mimState = results.state;",
                    "\tlet asrResults = results.asrResults;",
                    "\tlet speakerIds = results.speakerIds;",
                    "\tlet exception = results.exception;",
                    "\treturn exception;",
                    "}"
                ]
            },
            "name": "What Next?",
            "size": "725 55.82284749830794"
        },
