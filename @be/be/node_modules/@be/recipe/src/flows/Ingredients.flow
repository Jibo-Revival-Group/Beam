            "options": {
                "mimPath": "mims/en-us/Ingredients/ReadIngredients.mim",
                "getPromptData": [
                    "() => {",
                    "\tlet question_1 = blackboard.languageData.INGREDIENTS_READ_INGREDIENTS_PROMPT_1;",
