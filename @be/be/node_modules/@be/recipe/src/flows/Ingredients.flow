                    "    callback(notepad.activeIngredient);",
                    "}"
                ],
                "onWord": [
                    "(word) => {",
                    "}"
                ]
            },
            "name": "Read Ingredient"
        },
        {
            "class": "Mim.Question",
            "asset-pack": "core",
            "clazz": "Mim.Question",
            "loc": "591.5823262508461 253.5",
            "id": "831fdc04-98da-456c-8d98-f26c73b9b927",
            "options": {
                "mimPath": "mims/en-us/Ingredients/WhatNext.mim",
                "getPromptData": [
                    "() => {",
                    "\tlet data = {",
                    "\t\tagain: notepad.ingredientsRead ? 'again' : 'to you'",
                    "\t};",
                    "\tlet question_1 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.INGREDIENTS_WHAT_NEXT_PROMPT_1,",
                    "\t\tdata",
                    "\t);",
                    "\tlet noInput_1 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.INGREDIENTS_WHAT_NEXT_NO_INPUT_1,",
                    "\t\tdata",
                    "\t);",
                    "\tlet noMatch_1 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.INGREDIENTS_WHAT_NEXT_NO_MATCH_1,",
                    "\t\tdata",
                    "\t);",
                    "\treturn {",
                    "\t\tquestion_1,",
                    "\t\tnoInput_1,",
                    "\t\tnoMatch_1",
                    "\t};",
                    "}"
                ],
                "onStatus": [
                    "(status) => {",
                    "",
                    "}"
                ],
                "onSuccess": [
                    "(results) => {",
                    "\tlet { ingredient, response } = results.asrResults.NLParse;",
                    "\tnotepad.requestedIngredient = ingredient;",
                    "\treturn response;",
                    "}"
                ],
                "onFailure": [
                    "(results) => {",
                    "\tlet mimState = results.state;",
                    "\tlet asrResults = results.asrResults;",
                    "\tlet speakerIds = results.speakerIds;",
                    "\tlet exception = results.exception;",
                    "\treturn exception;",
                    "}"
                ]
            },
            "name": "What Next?",
            "size": "424 55.82284749830794"
        },
        {
            "class": "Mim.Announcement",
            "asset-pack": "core",
            "clazz": "Mim.Announcement",
            "loc": "569.4933153694029 338.6140912869384",
            "id": "e19c726f-84d0-4a98-920b-3371ad95868c",
            "options": {
                "mimPath": "mims/en-us/Ingredients/HowMany.mim",
                "getPromptData": [
                    "() => {",
                    "\tlet data = { num: notepad.numIngredients };",
                    "\tlet announcement_1 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.INGREDIENTS_HOW_MANY_PROMPT_1,",
                    "\t\tdata",
                    "\t);",
                    "\treturn {",
                    "\t\tannouncement_1",
                    "\t};",
                    "}",
                    "",
                    ""
                ]
            },
            "name": "How Many"
        },
        {
            "class": "Mim.Announcement",
            "asset-pack": "core",
            "clazz": "Mim.Announcement",
            "loc": "436.47608418367327 338.47488288044576",
            "id": "7976db7e-ef3b-4158-967b-fea77b459c16",
            "options": {
                "mimPath": "mims/en-us/Ingredients/HowMuch.mim",
                "getPromptData": [
                    "() => {",
                    "\tlet ingredient = notepad.requestedIngredient;",
                    "\tlet re = new RegExp(ingredient, 'i');",
                    "\tlet notFound = true;",
                    "\tfor (let i = 0; i < notepad.numIngredients; i++) {",
                    "\t\t\tlet val = notepad.ingredients[i].displayValue;",
                    "\t\t\tif (re.test(val)) {",
                    "\t\t\t\tnotFound = false;",
                    "\t\t\t\tingredient = val;",
                    "\t\t\t\tbreak;",
                    "\t\t\t}",
                    "\t}",
                    "\tlet data = { ingredient };",
                    "\tlet announcement_1 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.INGREDIENTS_HOW_MUCH_PROMPT_1,",
                    "\t\tdata",
                    "\t);",
                    "\tlet announcement_2 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.INGREDIENTS_HOW_MUCH_PROMPT_2,",
                    "\t\tdata",
                    "\t);",
                    "\treturn {",
                    "\t\tannouncement_1,",
                    "\t\tannouncement_2,",
                    "\t\tnotFound",
                    "\t};",
                    "}",
                    "",
                    ""
                ]
            },
            "name": "How Much"
        },
        {
            "class": "Flow.Eval",
            "clazz": "Flow.Eval",
            "loc": "505.02724965172496 60.5",
            "id": "c3bb99d7-62eb-4649-be18-44e58f5ab78a",
            "options": {
                "Script": [
                    "() => {",
                    "  notepad.ingredients = blackboard.activeRecipe.ingredients;",
                    "  notepad.numIngredients = notepad.ingredients.length;",
                    "  notepad.activeIngredient = '';",
                    "  notepad.requestedIngredient = '';",
                    "  notepad.activeIndex = 0;",
                    "  notepad.ingredientsRead = false;",
                    "  notepad.view = blackboard.skill.ingredientsView;",
                    "  notepad.view.toggleMakeIt(blackboard.navigation.getPreviousView() === 'recipe-selection');",
                    "  ",
                    "  let id = blackboard.activeRecipe.recipeID;",
                    "  if (blackboard.stateModel.viewedIngredients(id)) {",
                    "    return 'yes';",
                    "  } else {",
                    "    blackboard.stateModel.addViewedIngredientList(id);",
                    "    return 'no';",
                    "  }",
                    "}"
                ]
            },
            "name": "Viewed Ingredients Already?",
            "size": "258 55.82284749830794"
        },
