                    "\tlet asrResults = results.asrResults;",
                    "\tlet speakerIds = results.speakerIds;",
                    "\tlet exception = results.exception;",
                    "\treturn exception;",
                    "}"
                ]
            },
            "name": "Read Ingredients?",
            "size": "209 55.82284749830794"
        },
        {
            "class": "Flow.Eval-Async",
            "clazz": "Flow.Eval-Async",
            "loc": "250.13772311802768 253.58511253783544",
            "id": "3f5b67fa-fbc4-44e0-9520-e6a8c3c67bd3",
            "options": {
                "exec": [
                    "(done) => {",
                    "  if (notepad.activeIndex === notepad.numIngredients) {",
                    "    notepad.activeIndex = 0;",
                    "    notepad.activeIngredient = '';",
                    "    notepad.view.removeHighlight();",
                    "    done('done');",
                    "    return;",
                    "  }",
                    "  let ingredient = '';",
                    "  let index = notepad.activeIndex;",
                    "  while (index !== notepad.numIngredients && ingredient.length === 0) {",
                    "    ingredient = notepad.ingredients[index++].displayValue;",
                    "  }",
                    "  notepad.activeIngredient = ingredient;",
                    "  notepad.ingredientsRead = true;",
                    "  notepad.view.highlight(notepad.activeIndex++, done);",
                    "}"
                ],
                "onStop": [
                    "() => { }"
                ]
            },
            "name": "Loop Ingredients"
        },
        {
            "class": "TextToSpeechJs",
