            "options": {
                "words": "Say Cheese!",
                "onWord": [
                    "(word) => {",
                    "}"
                ]
            },
            "id": "41c9b677-345c-4f75-b3e6-68e6a6ca467e",
            "name": "Say Cheese"
        },
        {
            "class": "LookAt",
            "asset-pack": "core",
            "clazz": "LookAt",
            "loc": "335.015625 270",
            "options": {
                "getTarget": [
                    "() => {",
                    "\tlet jibo = require('jibo');\t",
                    "\tlet entity = jibo.lps.getClosestVisualEntity();",
                    "\t",
                    "\t// x is meters forward, y is meters left, and z is meters up",
                    "  let nDefaultPosition = {x: 0.1, y: 0, z: 0.285}; // emulates initial \"center\"",
                    "  let position = nDefaultPosition;",
                    "",
                    "\tif (entity && entity.parts.length > 0) {",
                    "\t\tlet raysData = entity.parts[0].value.rays;",
                    "\t\tif (raysData !== undefined && raysData.length > 0) {",
                    "\t\t\tlet origin = entity.parts[0].value.rays[0].origin;",
                    "\t\t\tlet dir = entity.parts[0].value.rays[0].dir;",
                    "\t\t\tposition\t= {x: dir.x + origin.x, y:dir.y + origin.y, z: dir.z + origin.z};",
                    "\t\t}",
                    "\t}",
                    "\treturn position;",
                    "}"
                ],
                "isContinuous": false,
                "config": [
                    "(lookAt) => {",
                    "}"
                ]
            },
            "id": "5890aa14-85c2-446e-becf-0b1aef3826dd",
            "name": "Take for face"
        },
        {
            "class": "TakePhoto",
            "asset-pack": "core",
            "clazz": "TakePhoto",
            "loc": "335.56687672692027 378.9842816840507",
            "id": "dd48d089-7b23-436b-acde-255c3ef694bc",
            "options": {
                "resolution": 2,
                "onPhoto": [
                    "(error, imageUrl) => {",
                    "  console.log(\"imageURL\", imageUrl);",
                    "  notepad.imageUrl = imageUrl;",
                    "}"
                ],
                "noDistortion": true
            },
            "name": "Take Photo",
            "size": "146 66.03521884980772"
        },
        {
            "class": "Flow.Eval",
            "clazz": "Flow.Eval",
            "loc": "335.015625 473",
            "options": {
                "Script": [
                    "() => {",
                    "  jibo.face.renderOnlyWhenDirty = false; ",
                    "",
                    "// create new Pixi sprite",
                    "notepad.photo = new PIXI.Sprite();",
                    "",
                    "// set the texture of the sprite to the imageURL",
                    "notepad.photo.texture = PIXI.Texture.fromImage(notepad.imageUrl);",
                    "",
                    "// add the sprite to the stage",
                    "jibo.face.stage.addChild(notepad.photo);",
                    "    return '';",
                    "}"
                ]
            },
            "id": "3ab28b83-875e-4de0-8fff-44a649e53a0e",
            "name": "Create Photo"
        },
        {
            "class": "TimeoutJs",
            "asset-pack": "core",
            "clazz": "TimeoutJs",
            "loc": "334.828125 580",
            "id": "5c36e029-fb49-4a9d-8d87-4654dfa47377",
            "options": {
                "getTime": [
                    "() => {",
                    "    return 10000;",
                    "}"
                ]
            },
            "name": "Pause for 3 secs"
        },
        {
            "class": "Flow.Eval",
            "clazz": "Flow.Eval",
            "loc": "334.015625 669",
            "options": {
                "Script": [
                    "() => {",
                    "  //remove the image from the screen",
                    "  jibo.face.stage.removeChild(notepad.photo); ",
                    "",
                    "//force draw",
                    "  jibo.face.update(); ",
                    "",
                    "//render only when dof values are dirty",
                    "  jibo.face.renderOnlyWhenDirty = true; ",
                    "    return '';",
                    "}"
                ]
            },
            "id": "49d8295f-7d2f-4d90-a5e3-38223d7ebd0f",
            "name": "Show Eye"
        },
        {
            "class": "Flow.Catch",
