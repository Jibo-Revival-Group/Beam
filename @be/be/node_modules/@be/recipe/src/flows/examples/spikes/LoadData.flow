            "clazz": "Flow.Eval-Async",
            "loc": "452 53",
            "id": "30c03b62-7a8d-4898-899c-0c35c694e0a9",
            "options": {
                "exec": [
                    "(done) => {",
                    "  let fs = require('fs');",
                    "  let path = require ('path');",
                    "  let dir = __dirname;",
                    "  let fileName = __filename;",
                    "  let dataPath = require('../../data/mulitplerecipes.json');",
                    "  let beefRecipe1 =  require('../../data/beef/barbecuedbeef.json');",
                    "  let beefRecipe2 =  require('../../data/beef/beefbulgogi.json');",
                    "  let fishRecipe1 =  require('../../data/fish/fishchowder.json');",
                    "  let fishRecipe2 =  require('../../data/fish/fishtacos.json');",
                    "  let chickenRecipe1 =  require('../../data/chicken/chickencordonblue.json');",
                    "  let chickenRecipe2 =  require('../../data/chicken/chickenpotpie.json');",
                    "  let dessertRecipe1 =  require('../../data/dessert/dessertcrepes.json');",
                    "  let dessertRecipe2 =  require('../../data/dessert/dessertpizza.json');",
                    "",
                    "  notepad.clipsPath = 'resources/views/TitleScreen.json';",
                    "  ",
                    "  blackboard.dir = dir;",
                    "  blackboard.path = path;",
                    "  blackboard.fs = fs;",
                    "  ",
                    "  if (blackboard.dataLoaded == null) {",
                    "    blackboard.recipeModel.loadFiles([",
                    "      beefRecipe1, beefRecipe2,",
                    "      fishRecipe1,fishRecipe2,",
                    "      chickenRecipe1,chickenRecipe2,",
                    "      dessertRecipe1, dessertRecipe2",
                    "    ])",
                    "  }",
                    "",
                    "  ",
                    "  blackboard.dataLoaded = true;",
                    "  ",
                    "  done(notepad.selectedOption);",
                    "}"
                ],
                "onStop": [
                    "() => { }"
                ]
            },
            "name": "initialize"
        },
