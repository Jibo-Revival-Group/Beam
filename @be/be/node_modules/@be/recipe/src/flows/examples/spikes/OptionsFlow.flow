        {
            "class": "Listen",
            "asset-pack": "core",
            "clazz": "Listen",
            "loc": "210.453125 463",
            "id": "5f01d504-4da1-47d0-bfed-5d0d599c34a7",
            "options": {
                "getOptions": [
                    "() => {",
                    "    let options = {",
                    "        heyJibo: false,",
                    "        detectEnd: false,",
                    "        incremental: true,",
                    "        authenticateSpeaker: ''",
                    "    }",
                    "    return options;",
                    "}"
                ],
                "rule": "Options.fst",
                "onResult": [
                    "(listener) => {",
                    "    listener.on('cloud', function(asrResult, speakerIds) {",
                    "        console.log('cloud:', asrResult)",
                    "        notepad.selectedOption = asrResult.NLParse.selectedOption;",
                    "    });",
                    "    ",
                    "    listener.on('incremental', function(asrResult, speakerIds) {",
                    "      console.log('incremental', asrResult);",
                    "    });",
                    "}"
                ]
            },
            "name": "Listen for instruction"
        },
