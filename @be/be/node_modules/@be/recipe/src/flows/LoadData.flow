            "options": {
                "Script": [
                    "() => {",
                    "    // filtering currently handled by the model.",
                    "    // sorting unhandled, not sure where it would be handled. probably the model again.",
                    "    let { method, args } = notepad.params;",
                    "    if (!Array.isArray(args)) { args = [ args ]; }",
                    "    notepad.results = blackboard.recipeModel[method](...args);",
                    "    return notepad.results.length > 0 ? '' : 'no-results';",
                    "}"
                ]
            },
            "name": "Filter/Sort"
