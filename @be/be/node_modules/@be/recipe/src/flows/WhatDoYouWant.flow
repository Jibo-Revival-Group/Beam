    "nodeDataArray": [
        {
            "class": "Mim.Question",
            "clazz": "Mim.Question",
            "loc": "1287.9736386235265 -298.9966749108107",
            "id": "f2339143-cd0e-442c-8db1-538e18e1f05d",
            "options": {
                "mimPath": "mims/en-us/WhatDoYouWant/WhatDoYouWant.mim",
                "getPromptData": [
                    "() => {",
                    "\tlet shortMessage = notepad.params.searches >= 1;",
                    "\tlet meal = blackboard.Helper.getMeal();",
                    "\t// TODO: Localize greeting",
                    "\tlet greeting = 'Good ';",
                    "\tswitch (meal) {",
                    "\t\tcase 'breakfast': greeting += 'morning'; break;",
                    "\t\tcase 'lunch': greeting += 'afternoon'; break;",
                    "\t\tcase 'dinner': greeting += 'evening'; break;",
                    "\t}",
                    "\t",
                    "\tlet data = {",
                    "\t\tname: blackboard.userModel.name,",
                    "\t\tmeal,",
                    "\t\tgreeting,",
                    "\t};",
                    "\t",
                    "\tlet question_1 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.WHAT_DO_YOU_WANT_WHAT_DO_YOU_WANT_PROMPT_1,",
                    "\t\tdata",
                    "\t);",
                    "\t",
                    "\tlet question_2 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.WHAT_DO_YOU_WANT_WHAT_DO_YOU_WANT_PROMPT_2,",
                    "\t\tdata",
                    "\t);",
                    "\t",
                    "\tlet question_3 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.WHAT_DO_YOU_WANT_WHAT_DO_YOU_WANT_PROMPT_3,",
                    "\t\tdata",
                    "\t);",
                    "\t",
                    "\tlet question_4 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.WHAT_DO_YOU_WANT_WHAT_DO_YOU_WANT_PROMPT_4,",
                    "\t\tdata",
                    "\t);",
                    "\t",
                    "\tlet noInput_1 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.WHAT_DO_YOU_WANT_WHAT_DO_YOU_WANT_NO_INPUT_1,",
                    "\t\tdata",
                    "\t);",
                    "\t",
                    "\treturn {",
                    "\t\tshortMessage,",
                    "\t\tquestion_1,",
                    "\t\tquestion_2,",
                    "\t\tquestion_3,",
                    "\t\tquestion_4,",
                    "\t\tnoInput_1",
                    "\t};",
                    "}"
                ],
                "onStatus": [
                    "(status) => {",
                    "\t",
                    "}"
                ],
                "onSuccess": [
                    "(results) => {",
                    "\tvar asr = (results && results.asrResults) ? results.asrResults : {};",
                    "\tvar ent = asr.entities || {};",
                    "\tvar nl = asr.NLParse || {};",
                    "\t// A tapped gui.Menu button arrives as a spoofed intent; speech (when",
                    "\t// grammars are available) arrives via NLParse. Accept whichever exists.",
                    "\tvar choice = (asr.intent || ent.choice || ent.response || nl.response || asr.text || '').toString().toLowerCase().trim();",
                    "\tif (choice === 'veggie') { choice = 'vegetarian'; }",
                    "\tvar categories = ['chicken', 'beef', 'fish', 'dessert', 'vegetarian'];",
                    "\tif (categories.indexOf(choice) !== -1) {",
                    "\t\tnotepad.token = notepad.query.args = choice;",
                    "\t\tnotepad.query.meal = '';",
                    "\t\tnotepad.query.method = 'getRecipesByGenericFilter';",
                    "\t\treturn 'token';",
                    "\t}",
                    "\tif (choice === 'favorites' || choice === 'favorite') {",
                    "\t\tnotepad.query.method = 'getFavorites';",
                    "\t\t// The Favorites node is wired to the default (empty) transition,",
                    "\t\t// there is no link literally named 'favorites'.",
                    "\t\treturn '';",
                    "\t}",
                    "\tif (choice === 'token' && nl.token) {",
                    "\t\tnotepad.token = notepad.query.args = nl.token;",
                    "\t\tnotepad.query.meal = nl.meal;",
                    "\t\tnotepad.query.method = 'getRecipesByGenericFilter';",
                    "\t\treturn 'token';",
                    "\t}",
                    "\tnotepad.query.method = 'getRecommendations';",
                    "\treturn 'recommendation';",
                    "}"
                ],
                "onFailure": [
                    "(results) => {",
                    "\t// no error handling necessary, just provide a recommendation",
                    "\tnotepad.query = { method: 'getRecommendations' };",
                    "\treturn 'recommendation';",
                    "}"
                ]
            },
            "name": "What Do You Want?"
        },
        {
            "class": "Flow.End",
            "clazz": "Flow.End",
            "loc": "1505.43377809181 -30.863957880045916",
            "id": "967e86fc-8140-4621-8ad5-b10fb9b20e76",
            "options": {
