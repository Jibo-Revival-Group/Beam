            "loc": "818.3049244603218 631.2531665748851",
            "id": "03053af6-38fa-4f97-9c59-f433ec978de9",
            "options": {
                "exec": [
                    "(done) => {",
                    "  if (notepad.input) {",
                    "    if (/favorite/.test(notepad.input)) {",
                    "      blackboard.stateModel.addFavoriteRecipe(blackboard.activeRecipe.recipeID);",
                    "      notepad.view.favorite(done);",
                    "      return;",
                    "    }",
                    "  } else {",
                    "    blackboard.stateModel.addFavoriteRecipe(blackboard.activeRecipe.recipeID);",
                    "    notepad.view.favorite(done);",
                    "    return;",
                    "  }",
                    "  ",
                    "  done();",
                    "}"
                ],
                "onStop": [
                    "() => { }"
                ]
            },
            "name": "Favorite"
        },
