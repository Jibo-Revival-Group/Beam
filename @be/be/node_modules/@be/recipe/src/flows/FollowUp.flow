        {
            "class": "TextToSpeechJs",
            "asset-pack": "core",
            "clazz": "TextToSpeechJs",
            "loc": "817.080630620297 476.35221697585564",
            "id": "d470024c-520d-489f-b25c-fedb52f6c4ce",
            "options": {
                "getWords": [
                    "(callback) => {",
                    "    callback(`",
                    "      If you enjoyed ${blackboard.activeRecipe.title}, tap the heart or say \"favorite\" to favorite it!",
                    "      This view will close in 10 seconds, or if you say \"close\".",
                    "    `);",
                    "}"
                ],
                "onWord": [
                    "(word) => {",
                    "}"
                ]
            },
            "name": ""
        },
        {
            "class": "ListenJs",
            "asset-pack": "core",
            "clazz": "ListenJs",
            "loc": "818.2955033213444 538.6931037661981",
            "id": "5cc2cc6c-9f22-4f9b-a2ed-6d6d0d5d3dc1",
            "options": {
                "getOptions": [
                    "() => {",
                    "    let options = {",
                    "        heyJibo: false,",
                    "        detectEnd: true,",
                    "        incremental: false,",
                    "        authenticateSpeaker: ''",
                    "    }",
                    "    return options;",
                    "}"
                ],
                "getRule": [
                    "(callback) => {",
                    "    callback(\"TopRule = $* (unfavorite | favorite | close) $*;\");",
                    "}"
                ],
                "onResult": [
                    "(listener) => {",
                    "    listener.on('cloud', function(asrResult, speakerIds) {",
                    "      notepad.input = asrResult.Input;",
                    "    });",
                    "}"
                ]
            },
            "name": ""
        },
