        {
            "class": "Mim.Question",
            "clazz": "Mim.Question",
            "loc": "574.4648577496004 202.79616003619893",
            "id": "8c45e34b-68e4-4539-bd13-c7f23b5c9051",
            "options": {
                "mimPath": "mims/en-us/Main/ContinueOrRestart.mim",
                "getPromptData": [
                    "() => {",
                    "\tlet data = {",
                    "\t\tstep: blackboard.Helper.stepToString(blackboard.activeStep),",
                    "\t\ttitle: blackboard.activeRecipe.title",
                    "\t};",
                    "\t",
                    "\tlet question_1 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.MAIN_CONTINUE_OR_RESTART_PROMPT_1,",
                    "\t\tdata",
                    "\t);",
                    "\t",
                    "\tlet noInput_1 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.MAIN_CONTINUE_OR_RESTART_NO_INPUT_1,",
                    "\t\tdata",
                    "\t);",
                    "\t",
                    "\tlet noMatch_1 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.MAIN_CONTINUE_OR_RESTART_NO_MATCH_1,",
                    "\t\tdata",
                    "\t);",
                    "\t\t",
                    "\treturn {",
                    "\t\tquestion_1,",
                    "\t\tnoInput_1,",
                    "\t\tnoMatch_1",
                    "\t};",
                    "}",
                    ""
                ],
                "onStatus": [
                    "(status) => {",
                    "",
                    "}"
                ],
                "onSuccess": [
                    "(results) => {",
                    "\tvar asr = (results && results.asrResults) || {};",
                    "\tvar nl = asr.NLParse || {};",
                    "\t// Tapped gui.Menu button = spoofed intent (firstGrammarTag); speech = NLParse.",
                    "\tvar choice = (results.firstGrammarTag || asr.intent || nl.response || '').toString().toLowerCase().trim();",
                    "\tif (choice === 'restart') {",
                    "\t\tblackboard.stateModel.refreshState().then(() => blackboard.skill.updateState());",
                    "\t\tnotepad.nextPath = blackboard.navigation.WhatDoYouWant;",
                    "\t} else {",
                    "\t\tnotepad.nextPath = blackboard.navigation.GuidedSteps;",
                    "\t}\t\t",
                    "\treturn '';",
                    "}",
                    ""
                ],
                "onFailure": [
                    "(results) => {",
                    "\tlet mimState = results.state;",
                    "\tlet asrResults = results.asrResults;",
                    "\tlet speakerIds = results.speakerIds;",
                    "\tlet exception = results.exception;",
                    "\treturn exception;",
                    "}"
                ]
            },
            "name": "Continue Or Restart?"
        },
