            "options": {
                "subflowId": "./WhatDoYouWant",
                "inputParameters": [
                    "() => {",
                    "  return {",
                    "    searches: notepad.searches++",
                    "  };",
                    "}"
                ],
                "getTransition": [
                    "(results) => {",
                    "  let transition = results.transition;",
                    "  if (typeof transition === 'string') {",
                    "    notepad.nextPath = transition;",
                    "  } else {",
                    "    notepad.query = transition;",
                    "    notepad.nextPath = blackboard.navigation.LoadData; ",
                    "  } ",
                    "  return '';",
                    "}"
                ]
            },
            "name": "What Do You Want"
        },
