        {
            "class": "Mim.Question",
            "clazz": "Mim.Question",
            "loc": "704.2691370768393 294.93883721288955",
            "id": "1ae1efb3-2019-4634-9734-ed78cac1db2e",
            "options": {
                "mimPath": "mims/en-us/Video/WhatNext.mim",
                "getPromptData": [
                    "() => {",
                    "\tlet question_1 = blackboard.languageData.VIDEO_WHAT_NEXT_PROMPT_1;",
                    "\tlet question_2 = blackboard.languageData.VIDEO_WHAT_NEXT_PROMPT_2;",
                    "\tlet noMatch_1 = blackboard.languageData.VIDEO_WHAT_NEXT_NO_MATCH_1;",
                    "\t// prevent jibo from talking while the video is playing",
                    "\tif (notepad.silence === false && notepad.view.isPlaying) {",
                    "\t\tnotepad.view.pauseVideo();",
                    "\t}",
                    "\treturn {",
                    "\t\tsilence: notepad.silence,",
                    "\t\tnoMatch: notepad.noMatch,",
                    "\t\tcame_from: blackboard.navigation.getPreviousView(),",
                    "\t\tquestion_1,",
                    "\t\tquestion_2,",
                    "\t\tnoMatch_1",
                    "\t};",
                    "}",
                    "",
                    ""
                ],
                "onStatus": [
                    "(status) => {",
                    "\t",
                    "}"
                ],
                "onSuccess": [
                    "(results) => {",
                    "\tlet nl = results.asrResults.NLParse;",
                    "\tlet r = nl.response;",
                    "\tnotepad.silence = true;",
                    "\tnotepad.noMatch = false;",
                    "\tnotepad.jumpTo = nl.step;",
                    "\tif (r === 'play' || r === 'pause') {",
                    "\t\tnotepad.action = r;",
                    "\t\tr = 'play-pause';",
                    "\t}",
                    "\treturn r;",
                    "}",
                    ""
                ],
                "onFailure": [
                    "(results) => {",
                    "\tnotepad.silence = results.state.lastResultState === 'noInput';",
                    "\tnotepad.noMatch = !notepad.silence;",
                    "\treturn '~Loop';",
                    "}"
                ]
            },
            "name": "What Next",
            "size": "434 55.82284749830794"
        },
