            "options": {
                "Script": [
                    "() => {",
                    "  if (notepad.view.isPlaying) {",
                    "    notepad.view.pauseVideo();",
                    "  } else {",
                    "    notepad.view.playVideo();",
                    "  }",
                    "  return '';",
                    "}"
                ]
            },
