            "options": {
                "mimPath": "mims/en-us/GuidedSteps/IngredientsOrRecipe.mim",
                "getPromptData": [
                    "() => {",
                    "\tlet question_1 = blackboard.languageData.GUIDED_STEPS_INGREDIENTS_OR_RECIPE_PROMPT;",
                    "\treturn {",
                    "\t\tquestion_1",
                    "\t};",
                    "}"
                ],
                "onStatus": [
                    "(status) => {",
                    "\t",
                    "}"
                ],
                "onSuccess": [
                    "(results) => {",
                    "\tvar asr = (results && results.asrResults) || {};",
                    "\tvar nl = asr.NLParse || {};",
                    "\t// Tapped gui.Menu button = spoofed intent (firstGrammarTag); speech = NLParse.",
                    "\treturn (results.firstGrammarTag || asr.intent || nl.response || '').toString().toLowerCase().trim();",
                    "}"
                ],
                "onFailure": [
                    "(results) => {",
                    "\tlet mimState = results.state;",
                    "\tlet asrResults = results.asrResults;",
                    "\tlet speakerIds = results.speakerIds;",
                    "\tlet exception = results.exception;",
                    "\treturn exception;",
                    "}"
                ]
            },
            "name": "Ingredients or Recipe?"
        },
        {
            "class": "Mim.Question",
            "clazz": "Mim.Question",
            "loc": "365.82696579493205 55.418045208273256",
            "id": "4c74b801-a4c7-418c-bfd4-3ad616f191fd",
            "options": {
                "mimPath": "mims/en-us/Generics/Ready.mim",
                "getPromptData": [
                    "() => {",
                    "\tlet data = {",
                    "\t\tappend: blackboard.languageData.START_MESSAGE",
                    "\t};",
                    "\tlet question_1 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.GENERICS_READY_PROMPT,",
                    "\t\tdata",
                    "\t);",
                    "\tlet noInput_1 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.GENERICS_READY_NO_INPUT,",
                    "\t\tdata",
                    "\t);",
                    "\tlet noMatch_1 = blackboard.StringUtils.supplant(",
                    "\t\tblackboard.languageData.GENERICS_READY_NO_MATCH,",
                    "\t\tdata",
                    "\t);",
                    "\treturn {",
                    "\t\tquestion_1,",
                    "\t\tnoInput_1,",
                    "\t\tnoMatch_1",
                    "\t};",
                    "}",
                    "",
                    ""
                ],
                "onStatus": [
                    "(status) => {",
                    "",
                    "}"
                ],
                "onSuccess": [
                    "(results) => {",
                    "\t// Ready is a single-choice confirm; any input (tap 'ready' or speech)",
                    "\t// proceeds via the node's default transition to Pre Step.",
                    "\treturn '';",
                    "}",
                    ""
                ],
                "onFailure": [
                    "(results) => {",
                    "\tlet mimState = results.state;",
                    "\tlet asrResults = results.asrResults;",
                    "\tlet speakerIds = results.speakerIds;",
                    "\tlet exception = results.exception;",
                    "\treturn exception;",
                    "}"
                ]
            },
            "name": "Ready"
        },
        {
            "class": "Flow.Eval-Async",
            "clazz": "Flow.Eval-Async",
            "loc": "419.31950687020816 -110.4151710064616",
            "id": "8d9fbdf0-6229-4256-aa9f-06eff1bf375b",
            "options": {
                "exec": [
                    "(done) => {",
                    "  blackboard.stateModel.setActiveRecipe(blackboard.activeRecipe.recipeID);",
                    "  notepad.directions = blackboard.activeRecipe.directions;",
                    "  notepad.silence = false;",
                    "  notepad.lastActiveStep = null;",
                    "  notepad.ignoreGUIAction = false;",
                    "  let nav = blackboard.navigation;",
                    "  if (blackboard.activeStep !== null) {",
                    "    let prev = nav.getPreviousView();",
                    "    if (prev === nav.Ingredients || prev === nav.Video) { notepad.silence = true; }",
                    "    notepad.view = blackboard.skill.stepView;",
                    "    done('in-progress');",
                    "    notepad.preStepActive = false;",
                    "  } else {",
                    "    blackboard.stateModel.setActiveStep(blackboard.activeStep = 1);",
                    "    notepad.view = blackboard.skill.mealView;",
                    "    notepad.preStepActive = true;",
                    "    done();",
                    "  }",
                    "}"
                ],
                "onStop": [
                    "() => { }"
                ]
            },
            "name": "Initialize"
        },
