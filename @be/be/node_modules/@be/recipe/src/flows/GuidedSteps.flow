        {
            "class": "Mim.Question",
            "clazz": "Mim.Question",
            "loc": "412.2249708086699 239.0022675736966",
            "id": "8da5197e-238e-4d44-b88c-7bd34f75c537",
            "options": {
                "mimPath": "mims/en-us/GuidedSteps/ReadStep.mim",
                "getPromptData": [
                    "() => {\t",
                    "\t// TODO: Put this in localization",
                    "\tlet step = blackboard.Helper.stepToString(blackboard.activeStep);",
                    "\tlet question_1 = `",
                    "\t\tStep ${step}.",
                    "\t\t${notepad.stepData.displayValue}.",
                    "\t`;",
                    "\t",
                    "\tlet isLastStep = blackboard.activeStep === notepad.directions.length;",
                    "\t",
                    "\tlet noInput_1 = `",
                    "\t\t${notepad.lastActiveStep !== null",
                    "\t\t\t? `Do you wanna to jump back to step ${blackboard.Helper.stepToString(notepad.lastActiveStep)}, or ${isLastStep ? 'complete the recipe?' : 'continue from here?'}`",
                    "\t\t\t: `${isLastStep",
                    "\t\t\t\t? 'That was the last step!'",
                    "\t\t\t\t: 'Let me know when you\\'re ready to continue'",
                    "\t\t\t}`",
                    "\t\t}",
                    "\t`;",
                    "\t",
                    "\treturn {",
                    "\t\tsilence: notepad.silence,",
                    "\t\tquestion_1,",
                    "\t\tnoInput_1,",
                    "\t\tnoMatch_1: `I didn't understand that. ${noInput_1}`",
                    "\t};",
                    "}"
                ],
                "onStatus": [
                    "(status) => {",
                    "\t",
                    "}"
                ],
                "onSuccess": [
                    "(results) => {",
                    "\tnotepad.silence = false;",
                    "\tlet nl = results.asrResults.NLParse;",
                    "\tlet r = nl.response;",
                    "\tif (r === 'nav') {",
                    "\t\tnotepad.ignoreGUIAction = true;",
                    "\t\tnotepad.stepAction = nl.step;",
                    "\t}",
                    "\treturn r;",
                    "}",
                    ""
                ],
                "onFailure": [
                    "(results) => {",
                    "\tlet exception = results.exception;",
                    "\treturn exception;",
                    "}"
                ]
            },
            "name": "Read Step",
            "size": "377 55.82284749830794"
        },
