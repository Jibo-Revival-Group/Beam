        {
            "class": "Flow.Eval",
            "clazz": "Flow.Eval",
            "loc": "274.97501006237513 398.9915332734937",
            "id": "8443e05f-4a8a-47c3-8f74-830f284f7781",
            "options": {
                "Script": [
                    "() => {",
                    "  switch (notepad.stepAction) {",
                    "    case 'next':",
                    "      if (blackboard.activeStep === notepad.directions.length) {",
                    "        return 'complete';",
                    "      }",
                    "      notepad.view.stepTo(++blackboard.activeStep);",
                    "      break;",
                    "    case 'previous':",
                    "      if (blackboard.activeStep === 1) {",
                    "        notepad.silence = true;",
                    "        return '';",
                    "      }",
                    "      notepad.view.stepTo(--blackboard.activeStep);",
                    "      break;",
                    "    case 'current': break; // nothing",
                    "    case 'back':",
                    "      // if a user triggers a back without being in a lastActive state,",
                    "      // just treat it as previous",
                    "      if (notepad.lastActiveStep === null) {",
                    "        --blackboard.activeStep;",
                    "      } else {",
                    "        blackboard.activeStep = notepad.lastActiveStep;",
                    "        notepad.lastActiveStep = null;",
                    "      }",
                    "      break;",
                    "    default:",
                    "      // specific step",
                    "      // normalize the step to a string, then set the activeStep to the number",
                    "      let step;",
                    "      try {",
                    "        step = blackboard.Helper.stepToString(notepad.stepAction);",
                    "        step = blackboard.Helper.stepToNumber(step);",
                    "        if (step > notepad.directions.length) {",
                    "          return '';",
                    "        }",
                    "      } catch (e) {",
                    "        // TODO: Display failure message.",
                    "        return '';",
                    "      }",
                    "      notepad.lastActiveStep = blackboard.activeStep;",
                    "      blackboard.activeStep = step;",
                    "      notepad.view.stepTo(step);",
                    "      break;",
                    "  }",
                    "  return '';",
                    "}"
                ]
            },
            "name": "Navigate"
        },
