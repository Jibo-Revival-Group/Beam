{
	"skill_id": "recipe",
	"mim_type": "question",
	"rule_name": "shared/yes_no",
	"rule_slots": "yes,no",
	"timeout": 6,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Touch-first; on-screen buttons drive this prompt. Original utterances: continue,new search",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "${question_1}",
			"media": "TTS",
			"prompt_id": "Q1"
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NI",
			"index": 1,
			"condition": "",
			"prompt": "${noInput_1}",
			"media": "TTS",
			"prompt_id": "NI1"
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NM",
			"index": 1,
			"condition": "",
			"prompt": "${noMatch_1}",
			"media": "TTS",
			"prompt_id": "NM1"
		}
	],
	"gui": {
		"type": "Menu",
		"data": {
			"title": "Continue where you left off?",
			"allowSwipe": true,
			"buttons": [
				{ "label": "Continue", "color": "default", "icon": "resources/icons/continue.png", "utterance": "continue", "notes": "" },
				{ "label": "New Search", "color": "default", "icon": "resources/icons/restart.png", "utterance": "restart", "notes": "" }
			]
		}
	},
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"parse_yes_no": false
}
