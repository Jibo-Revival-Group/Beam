{
	"skill_id": "recipe",
	"mim_type": "optional-response",
	"rule_name": "shared/yes_no",
	"rule_slots": "yes,no",
	"timeout": 6,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Touch-first; on-screen buttons drive this prompt. Original utterances: surprise me,meat,vegetarian",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "shortMessage === false",
			"prompt": "${question_1}",
			"media": "TTS",
			"prompt_id": "Q1"
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NI",
			"index": 1,
			"condition": "",
			"prompt": "${noInput_1}",
			"media": "TTS",
			"prompt_id": "NI1"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "shortMessage === false",
			"prompt": "${question_2}",
			"media": "TTS",
			"prompt_id": "Q2"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "shortMessage === false",
			"prompt": "${question_3}",
			"media": "TTS",
			"prompt_id": "Q3"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "shortMessage === true",
			"prompt": "${question_4}",
			"media": "TTS",
			"prompt_id": "Q4"
		}
	],
	"gui": {
		"type": "Menu",
		"data": {
			"title": "What do you want?",
			"allowSwipe": true,
			"buttons": [
				{ "label": "Chicken", "color": "default", "icon": "resources/icons/OptionsChicken.png", "utterance": "chicken", "notes": "" },
				{ "label": "Beef", "color": "default", "icon": "resources/icons/OptionsBeef.png", "utterance": "beef", "notes": "" },
				{ "label": "Fish", "color": "default", "icon": "resources/icons/OptionsFish.png", "utterance": "fish", "notes": "" },
				{ "label": "Dessert", "color": "default", "icon": "resources/icons/OptionsDessert.png", "utterance": "dessert", "notes": "" },
				{ "label": "Veggie", "color": "default", "icon": "resources/icons/OptionsVegetarian.png", "utterance": "vegetarian", "notes": "" },
				{ "label": "Favorites", "color": "default", "icon": "resources/icons/OptionsHelp.png", "utterance": "favorites", "notes": "" },
				{ "label": "Surprise Me", "color": "default", "icon": "resources/icons/OptionsHelp.png", "utterance": "recommendation", "notes": "" }
			]
		}
	},
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"ignore_no_match": false,
	"parse_launch": false,
	"parse_yes_no": false
}
