{
	"mim_type": "question",
	"rule_name": "rules/en-us/WhatDoYouWant/WhatDoYouWant.fst",
	"sample_utterances": "surprise me,meat,vegetarian",
	"timeout": 6,
	"num_tries_for_gui": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "shortMessage === false",
			"prompt": "${question_1}",
			"media": "TTS",
			"prompt_id": "Q1"
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NI",
			"index": 1,
			"condition": "",
			"prompt": "${noInput_1}",
			"media": "TTS",
			"prompt_id": "NI1"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "shortMessage === false",
			"prompt": "${question_2}",
			"media": "TTS",
			"prompt_id": "Q2"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "shortMessage === false",
			"prompt": "${question_3}",
			"media": "TTS",
			"prompt_id": "Q3"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "shortMessage === true",
			"prompt": "${question_4}",
			"media": "TTS",
			"prompt_id": "Q4"
		}
	]
}