{
	"skill_id": "recipe",
	"mim_type": "question",
	"rule_name": "shared/yes_no",
	"rule_slots": "yes,no",
	"timeout": 6,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Touch-first; on-screen buttons drive this prompt. Original utterances: next,ingredients,video,make this",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "firstRecipe === true && silence === false && numMatches > 1",
			"prompt": "${question_1}",
			"media": "TTS",
			"prompt_id": "Q1"
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NI",
			"index": 1,
			"condition": "",
			"prompt": "${noInput_1}",
			"media": "TTS",
			"prompt_id": "NI1"
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NM",
			"index": 1,
			"condition": "",
			"prompt": "${noMatch_1}",
			"media": "TTS",
			"prompt_id": "NM1"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "firstRecipe === false && silence === false && numMatches > 1",
			"prompt": "${question_2}",
			"media": "TTS",
			"prompt_id": "Q2"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "firstRecipe === false && silence === true",
			"prompt": "",
			"media": "silence",
			"prompt_id": "S"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "firstRecipe === true && silence === false && numMatches === 1",
			"prompt": "${question_3}",
			"media": "TTS",
			"prompt_id": "Q3"
		}
	],
	"gui": null,
	"no_matches_for_gui": 1,
	"no_inputs_for_gui": 1,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"parse_yes_no": false
}
