{
	"mim_type": "question",
	"rule_name": "rules/en-us/RecipeSelection/WhatNext.fst",
	"sample_utterances": "next,ingredients,video,make this",
	"timeout": 6,
	"num_tries_for_gui": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "firstRecipe === true && silence === false && numMatches > 1",
			"prompt": "${question_1}",
			"media": "TTS",
			"prompt_id": "Q1"
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NI",
			"index": 1,
			"condition": "",
			"prompt": "${noInput_1}",
			"media": "TTS",
			"prompt_id": "NI1"
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NM",
			"index": 1,
			"condition": "",
			"prompt": "${noMatch_1}",
			"media": "TTS",
			"prompt_id": "NM1"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "firstRecipe === false && silence === false && numMatches > 1",
			"prompt": "${question_2}",
			"media": "TTS",
			"prompt_id": "Q2"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "firstRecipe === false && silence === true",
			"prompt": "",
			"media": "silence",
			"prompt_id": "S"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "firstRecipe === true && silence === false && numMatches === 1",
			"prompt": "${question_3}",
			"media": "TTS",
			"prompt_id": "Q3"
		}
	]
}