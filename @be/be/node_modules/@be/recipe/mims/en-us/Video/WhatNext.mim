{
	"skill_id": "recipe",
	"mim_type": "question",
	"rule_name": "shared/yes_no",
	"rule_slots": "yes,no",
	"timeout": 10,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Touch-first; on-screen buttons drive this prompt. Original utterances: play,close",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "silence === true",
			"prompt": "",
			"media": "silence",
			"prompt_id": "S"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "silence === false && noMatch === true && came_from === 'recipe-selection'",
			"prompt": "${noMatch_1} ${question_1}",
			"media": "TTS",
			"prompt_id": "NM1"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "silence === false && noMatch === true && came_from === 'guided-steps'",
			"prompt": "${noMatch_1} ${question_2}",
			"media": "TTS",
			"prompt_id": "NM2"
		}
	],
	"gui": null,
	"no_matches_for_gui": 1,
	"no_inputs_for_gui": 1,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"parse_yes_no": false
}
