{
  "name": "@be/jukebox",
  "version": "0.1.0",
  "description": "Touchscreen MP3 player skill for Jibo. Drop .mp3 files in music/ and they show up automatically.",
  "main": "index.js",
  "config": {
    "standalone": true
  },
  "jibo": {
    "main": "index.html",
    "type": "asset-pack",
    "launchRule": "launch.rule",
    "prompt": "Jukebox",
    "display-name": "jukebox"
  },
  "monorailConfig": {
    "public": false,
    "output": "index.js"
  },
  "scripts": {
    "start": "jibo-dev watch",
    "watch": "jibo-dev watch",
    "build": "jibo-dev build",
    "clean": "jibo-dev clean",
    "build:release": "jibo-dev build --prod",
    "sync": "jibo-rsync",
    "addsshkey": "jibo-rsync --init"
  },
  "files": [
    "music",
    "resources",
    "index.*",
    "launch.rule"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=6.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@be/be-framework": "^11.0.0",
    "jibo": "^14.0.0",
    "jibo-dev": "^5.0.0",
    "jibo-flow-core": "^4.0.0",
    "jibo-rsync": "^4.0.0"
  },
  "syncDependencies": [
    "jibo",
    "@be/be-framework"
  ]
}
