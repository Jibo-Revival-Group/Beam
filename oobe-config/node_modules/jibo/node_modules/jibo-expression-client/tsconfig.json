{
    "note":"This project is compiled via jibo-gulp - this file is just for IDEs to use while editing",
    "compilerOptions": {
        "target": "ES6",
        "allowJs": true,
        "module": "commonjs",
        "moduleResolution": "node",
        "experimentalDecorators": true
    },
    "compileOnSave": false,
    "include": [
        "src/**/*.ts",
        "typings/index.d.ts"
    ],
    "exclude":[
        "assets",
        "behaviors",
        "bin",
        "configs",
        "lib",
        "node_modules",
        "parser",
        "rules",
        "tests",
        "static"
    ]
}
