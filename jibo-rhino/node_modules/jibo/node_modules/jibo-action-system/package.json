    "chai": "^3.5.0",
    "electron-prebuilt": "1.0.1",
    "find-root": "^1.0.0",
    "floss": "^1.2.4",
    "gulp": "^3.9.1",
    "jibo-dev": "^2.0.0",
    "jibo-gulp": "^3.6.1",
    "mkdirp": "^0.5.1",
    "sinon": "^1.17.6",
    "typescript": "^2.1.5",
    "typescript-definition-tester": "0.0.5"
  },
  "repository": {
    "type": "git",
    "url": "git@github.jibo.com:sdk/sdk.git"
  },
