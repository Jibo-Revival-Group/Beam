{
  "name": "jibo-action-system",
  "version": "1.6.0",
  "description": "This project supports both `*.js` files written in ES6 Javascript as well as `*.ts` files written in TypeScript. All get transpiled to ES5 Javascript.",
  "main": "lib/jibo-action-system.js",
  "typings": "dts/main.d.ts",
  "scripts": {
    "test:debug": "floss --path tests/index.js --debug --electron node_modules/electron-prebuilt/dist/Electron.app/Contents/MacOS/Electron",
    "test": "floss --path tests/index.js --electron node_modules/electron-prebuilt/dist/Electron.app/Contents/MacOS/Electron",
    "build": "gulp debug",
    "watch": "gulp watch",
    "build:release": "gulp",
    "clean": "gulp clean",
    "docs": "gulp docs",
    "docs:public": "gulp docs-public",
    "publish:patch": "gulp publish --yes --bump=patch",
    "publish:minor": "gulp publish --yes --bump=minor",
    "publish:major": "gulp publish --yes --bump=major",
    "publish:skip": "gulp publish --yes --bump=skip"
  },
  "dependencies": {
    "jibo-cai-utils": "^2.2.0",
    "jibo-log": "^2.0.4",
    "jibo-typed-events": "^3.2.2",
    "lodash": "^4.17.2"
  },
